{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug with ST-Link (OpenOCD)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Relay16CH_H750.elf",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "arm-none-eabi-gdb",
            "logging": {
                "engineLogging": false
            },
            "preLaunchTask": "CMake: Build Debug",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Connect to OpenOCD",
                    "text": "target extended-remote localhost:3333",
                    "ignoreFailures": false
                },
                {
                    "description": "Set debug speed",
                    "text": "monitor speed 1000",
                    "ignoreFailures": true
                }
            ],
            "postDebugTask": "OpenOCD: Stop Server"
        },
